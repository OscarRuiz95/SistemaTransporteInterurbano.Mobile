<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SistemaTransporteInterurbano.Mobile.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Iniciar sesión">

    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="20">

            <Label
                Text="Sistema de Transporte Interurbano"
                FontSize="26"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center" />

            <Label
                Text="Aplicación móvil para pasajeros"
                FontSize="16"
                TextColor="Gray"
                HorizontalTextAlignment="Center" />

            <Frame
                Padding="20"
                CornerRadius="18"
                HasShadow="True">

                <VerticalStackLayout Spacing="16">

                    <Label
                        Text="Iniciar sesión"
                        FontSize="22"
                        FontAttributes="Bold" />

                    <Entry
                        x:Name="NombreUsuarioEntry"
                        Placeholder="Nombre de usuario"
                        Keyboard="Text" />

                    <Entry
                        x:Name="ClaveEntry"
                        Placeholder="Clave"
                        IsPassword="True" />

                    <Label
                        x:Name="MensajeErrorLabel"
                        TextColor="Red"
                        IsVisible="False" />

                    <Button
                        x:Name="LoginButton"
                        Text="Iniciar sesión"
                        Clicked="OnLoginClicked" />

                    <ActivityIndicator
                        x:Name="CargandoIndicator"
                        IsRunning="False"
                        IsVisible="False" />

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>