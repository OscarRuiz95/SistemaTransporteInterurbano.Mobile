<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SistemaTransporteInterurbano.Mobile.Views.DetalleReservaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Detalle del Viaje">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F172A" Offset="0.0" />
            <GradientStop Color="#1E3A8A" Offset="0.55" />
            <GradientStop Color="#0891B2" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">

                <Button
                    Text="←"
                    BackgroundColor="#22FFFFFF"
                    TextColor="White"
                    CornerRadius="20"
                    WidthRequest="44"
                    HeightRequest="44"
                    Clicked="OnVolverClicked" />

                <Label
                    Grid.Column="1"
                    Text="Detalle"
                    FontSize="26"
                    FontAttributes="Bold"
                    TextColor="White"
                    VerticalOptions="Center" />

                <Button
                    Grid.Column="2"
                    Text="Salir"
                    BackgroundColor="#EF4444"
                    TextColor="White"
                    CornerRadius="22"
                    Padding="14,8"
                    VerticalOptions="Center"
                    Clicked="OnCerrarSesionClicked" />

            </Grid>

            <Border
                Padding="18"
                BackgroundColor="#22FFFFFF"
                Stroke="#44FFFFFF"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 22">

                <VerticalStackLayout Spacing="11">

                    <Label
                        Text="Información del viaje"
                        FontSize="21"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label x:Name="RutaLabel" TextColor="White" />
                    <Label x:Name="EstadoLabel" TextColor="#CCFFFFFF" />
                    <Label x:Name="OrigenLabel" TextColor="#CCFFFFFF" />
                    <Label x:Name="DestinoLabel" TextColor="#CCFFFFFF" />
                    <Label x:Name="UnidadLabel" TextColor="#CCFFFFFF" />
                    <Label x:Name="ChoferLabel" TextColor="#CCFFFFFF" />
                    <Label x:Name="FechaSalidaLabel" TextColor="#CCFFFFFF" />
                    <Label x:Name="FechaLlegadaLabel" TextColor="#CCFFFFFF" />
                    <Label x:Name="AsientoLabel" TextColor="White" FontAttributes="Bold" />

                </VerticalStackLayout>
            </Border>

            <Border
                Padding="18"
                BackgroundColor="#22FFFFFF"
                Stroke="#44FFFFFF"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 22">

                <VerticalStackLayout Spacing="11">

                    <Label
                        Text="Resumen de Pago"
                        FontSize="21"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label x:Name="PrecioBaseLabel" TextColor="#CCFFFFFF" />

                    <Label
                        x:Name="MontoPagadoLabel"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="#7DD3FC" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>