<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SistemaTransporteInterurbano.Mobile.Views.MisReservasPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Mis Reservas">

    <Grid Padding="20" RowDefinitions="Auto,*">

        <VerticalStackLayout Spacing="4">
            <Label Text="Mis Reservas"
                   FontSize="26"
                   FontAttributes="Bold" />

            <Label Text="Consulta tus viajes reservados"
                   FontSize="15"
                   TextColor="Gray" />
        </VerticalStackLayout>

        <CollectionView
            x:Name="ReservasCollection"
            Grid.Row="1"
            Margin="0,20,0,0"
            SelectionMode="Single"
            SelectionChanged="OnReservaSeleccionada">

            <CollectionView.EmptyView>
                <Label Text="No tienes reservas registradas."
                       HorizontalTextAlignment="Center"
                       TextColor="Gray" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="16"
                           Margin="0,0,0,12"
                           CornerRadius="16"
                           HasShadow="True">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding RutaTexto}"
                                   FontSize="18"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding EstadoTexto, StringFormat='Estado: {0}'}"
                                   FontSize="14"
                                   TextColor="Gray" />

                            <Label Text="{Binding NumeroAsiento, StringFormat='Asiento: {0}'}"
                                   FontSize="14" />

                            <Label Text="{Binding FechaSalidaTexto, StringFormat='Salida: {0:dd/MM/yyyy HH:mm}'}"
                                   FontSize="14" />
                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>